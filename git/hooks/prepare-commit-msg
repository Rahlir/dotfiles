#!/usr/bin/env zsh
# prepare-commit-msg: auto-generate a commit message with pi when running a
# plain `git commit` (no -m, no merge/squash/amend).

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="$2"   # set by git for: message (-m/-F), merge, squash, commit (-c/-C/--amend)

# Skip generation for anything other than a fresh empty commit
[ -n "$COMMIT_SOURCE" ] && exit 0

# Ensure ~/.local/bin (where pi lives) is on PATH in non-interactive shells
export PATH="$HOME/.local/bin:$PATH"

# Bail out silently if pi is not available
if ! command -v pi &>/dev/null; then
    exit 0
fi

# Get staged diff; exit silently if nothing is staged yet
DIFF=$(git diff --cached)
[ -z "$DIFF" ] && exit 0

echo "Generating commit message..." > /dev/tty

GENERATED=$(pi -p --no-tools --no-session --model gemini-3.1-flash-lite-preview \
    "Generate a git commit message for the following staged diff following the Conventional Commits 1.0.0 specification.

Format:
  <type>[optional scope]: <description>

  [optional body]

  [optional footer(s)]

Rules:
- type MUST be one of: feat, fix, build, chore, ci, docs, style, refactor, perf, test, revert
- Use feat for new features, fix for bug fixes
- scope is optional: a noun in parentheses describing the affected section, e.g. feat(parser):
- description: short summary in present tense, max 72 chars total for the first line
- Append ! after type/scope for breaking changes, e.g. feat! or feat(api)!
- Breaking changes MUST also have a 'BREAKING CHANGE: <description>' footer
- Body and footers are optional; separate each section with a blank line
- Output ONLY the commit message. No preamble, no markdown fences, no explanation.

Examples:
  feat(auth): add OAuth2 login support
  fix: prevent race condition in request handler
  docs: correct typo in README
  feat!: drop support for Node 6

  BREAKING CHANGE: Node 6 is no longer supported.

Staged diff:
$DIFF" 2>/dev/null)

[ -z "$GENERATED" ] && exit 0

# Prepend generated message, keeping the original template/comments below
ORIGINAL=$(cat "$COMMIT_MSG_FILE")
printf '%s\n%s\n' "$GENERATED" "$ORIGINAL" > "$COMMIT_MSG_FILE"
